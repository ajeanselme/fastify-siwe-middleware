{
    "compilerOptions": {
        "target": "ES2024",
        "module": "es2022",
        "isolatedModules": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0",
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}