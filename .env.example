# Copy this file to .env and adjust values for your environment.

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=siwe
DB_PASSWORD=secret
DB_DATABASE=siwe_auth
# DB_SCHEMA=public

# Redis
REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# Auth
JWT_SECRET=change-me
ALLOWED_DOMAIN=localhost:3000
# CHAIN_ID=1
# RPC_URL=https://your-rpc-url.example

# Limits and token settings
BODY_LIMIT_BYTES=8192
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
NONCE_RATE_LIMIT_MAX=10
NONCE_RATE_LIMIT_WINDOW_MS=60000
VERIFY_RATE_LIMIT_MAX=5
VERIFY_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX=10
REFRESH_RATE_LIMIT_WINDOW_MS=60000
REFRESH_TOKEN_TTL_SECONDS=604800